RewriteEngine On

# Вимкнути PageSpeed (Vite вже мінімізує і хешує файли)
<IfModule pagespeed_module>
  ModPagespeed off
</IfModule>

# Cache Control Headers
<IfModule mod_headers.c>
  # Hashed static assets (Vite generates unique filenames) — aggressive cache
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 7 day cache
  <FilesMatch "\.(png|jpg|jpeg|svg|ico|webp|gif)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # index.html / index.php — always revalidate
  <FilesMatch "^index\.(html|php)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Block indexing of admin/operator/login/panel pages
<IfModule mod_headers.c>
  <If "%{REQUEST_URI} =~ m#^/(admin|operator|login|panel)#">
    Header set X-Robots-Tag "noindex, nofollow"
  </If>
</IfModule>

# Forward API and static files to api.php proxy
RewriteRule ^api/(.*)$ /api.php [L,QSA]
RewriteRule ^static/(.*)$ /api.php [L,QSA]

# SPA routing — route through index.php for proper 404 status codes
# index.php checks routes_cache.json and returns HTTP 404 for unknown routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L]
