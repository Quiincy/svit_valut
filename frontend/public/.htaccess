RewriteEngine On

# Вимкнути PageSpeed (Vite вже мінімізує і хешує файли)
<IfModule pagespeed_module>
  ModPagespeed off
</IfModule>

# Cache Control Headers
<IfModule mod_headers.c>
  # Hashed static assets (Vite generates unique filenames) — aggressive cache
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 7 day cache
  <FilesMatch "\.(png|jpg|jpeg|svg|ico|webp|gif)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # index.html / index.php — always revalidate
  <FilesMatch "^index\.(html|php)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Роутинг React SPA (якщо файл не знайдено - віддаємо index.html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L]
